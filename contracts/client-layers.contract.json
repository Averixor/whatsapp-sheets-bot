{
  "version": 1,
  "includeOrderRef": "client-includes.contract.json",
  "layers": [
    {
      "id": "core",
      "files": [
        "Js.Core",
        "Js.State",
        "Js.Api"
      ],
      "allowedDependsOn": []
    },
    {
      "id": "render",
      "files": [
        "Js.Render.Panel",
        "Js.Render.Calendar",
        "Js.Render.Results"
      ],
      "allowedDependsOn": [
        "core"
      ]
    },
    {
      "id": "features",
      "files": [
        "Js.Vacations",
        "Js.Diagnostics",
        "Js.Security.Boot",
        "Js.Security.Util",
        "Js.Security.Access",
        "Js.Security.Debug",
        "Js.Security.Login",
        "Js.Security.DebugView",
        "Js.Security.Policy",
        "Js.Security.Guards",
        "Js.Security.Forms",
        "Js.Security.Exports",
        "Js.Helpers",
        "Js.Events",
        "Js.Actions"
      ],
      "allowedDependsOn": [
        "core",
        "render"
      ]
    }
  ],
  "runtimeBridges": [
    {
      "id": "SidebarApp",
      "definedIn": "Js.Actions",
      "definedLayer": "features",
      "consumerLayers": [
        "render",
        "features"
      ],
      "matchPatterns": [
        "\\bSidebarApp\\."
      ]
    }
  ],
  "forbiddenRefs": [
    {
      "id": "no-upward-layer-deps",
      "description": "Lower layers must not reference symbols defined in higher layers (except documented runtime bridges)."
    },
    {
      "id": "core-no-ui",
      "description": "Core layer must not call render or feature UI entrypoints.",
      "sourceLayer": "core",
      "forbiddenTargetLayers": [
        "render",
        "features"
      ]
    },
    {
      "id": "render-no-direct-features",
      "description": "Render layer must not call feature functions directly; use SidebarApp onclick bridge only.",
      "sourceLayer": "render",
      "forbiddenTargetLayers": [
        "features"
      ],
      "allowedPatterns": [
        "\\bSidebarApp\\."
      ]
    }
  ],
  "sharedUtilities": [
    "logToConsole",
    "handleError",
    "normalizeError",
