{
  "version": 2,
  "maxSafeExprPatterns": 100,
  "warnThreshold": 95,
  "legacyPatternCount": 94,
  "migrationNotes": "Prefer routing new HTML through sanitizerSinks (escapeHtml, escapeAttr, escapeJsString, esc) instead of expanding SAFE_EXPR. Legacy patterns remain allowed until sink migration completes.",
  "reviewedAllowlist": {
    "reviewedAt": "2026-06-06",
    "changeReason": "P2 explicit reviewed allowlist groups for SAFE_EXPR governance",
    "requireFullCoverage": true,
    "groups": [
      {
        "id": "sanitizer-sinks",
        "rationale": "Explicit HTML/attr/JS escape helpers",
        "patterns": [
          "^escapeHtml\\s*\\(",
          "^escapeHtmlMultiline\\s*\\(",
          "^esc\\s*\\(",
          "^escapeAttr\\s*\\(",
          "^escapeJsString\\s*\\(",
          "^escJs\\s*\\("
        ]
      },
      {
        "id": "render-helpers",
        "rationale": "Server-side render helpers that return pre-escaped HTML fragments",
        "patterns": [
          "^renderMultilineUiReportText_\\s*\\(",
          "^renderHealthGroup\\s*\\(",
          "^renderHealthReport\\s*\\(",
          "^renderProjectTestReport\\s*\\(",
          "^renderHealthCheckModeSwitcher_\\s*\\(",
          "^renderPendingRepairsTable_\\s*\\(",
          "^renderVacationAlerts\\s*\\(",
          "^renderBirthdayResult\\s*\\(",
          "^renderSelectedRecipientSendButton_\\s*\\(",
          "^renderSupplementaryBlocks\\s*\\(",
          "^renderAccessDebugResult_\\s*\\(",
          "^renderCheckItemCompact\\s*\\(",
          "^items\\.map\\s*\\(\\s*renderCheckItemCompact\\s*\\)",
          "^preview\\.map\\s*\\(",
          "^getHealthCheckModeLabel_\\s*\\(",
          "^getHealthCheckModeLabel_\\s*\\(\\)",
          "^renderHealthCheckModeSwitcher_\\s*\\(\\)"
        ]
      },
      {
        "id": "formatters",
        "rationale": "Formatting helpers returning escaped text or numeric labels",
        "patterns": [
          "^normalizeError\\s*\\(",
          "^translateLifecycle",
          "^formatOperationDate\\s*\\(",
          "^formatPhone\\s*\\(",
          "^formatBirthday",
          "^monthNames\\s*\\["
        ]
      },
      {
        "id": "numeric-coercions",
        "rationale": "Non-HTML numeric or length coercions",
        "patterns": [
          "^Number\\s*\\(",
          "^String\\s*\\(\\s*pct\\s*\\)",
          "^String\\s*\\(\\s*currentOffset",
          "^String\\s*\\(\\s*knownTotal",
          "^String\\s*\\(\\s*chunkNo",
          "^\\w+\\.length\\b"
        ]
      },
      {
        "id": "escaped-collections",
        "rationale": "Arrays mapped through escapeHtml",
        "patterns": [
          "^\\w+\\.map\\s*\\(\\s*escapeHtml\\s*\\)",
          "^protectedSheets\\.map\\s*\\(\\s*escapeHtml\\s*\\)",
          "^warnings\\.map\\s*\\(\\s*escapeHtml\\s*\\)"
        ]
      },
      {
        "id": "structured-data",
        "rationale": "Known-safe structured counters and report metadata",
        "patterns": [
          "^stats\\.",
          "^result\\?\\.",
          "^result\\.",
          "^data\\.(peopleCount|length)\\b",
          "^data\\.(commanderMessages|birthdayMessages|today|tomorrow)\\.length\\b",
          "^groups\\.",
          "^checks\\.length",
          "^report\\.(ts|startedAt|durationMs|runId)",
          "^new Date\\s*\\(",
          "^parts\\.join",
          "^JSON\\.stringify\\s*\\(\\s*access"
        ]
      },
      {
        "id": "allowlisted-scalars",
        "rationale": "Reviewed scalar identifiers used only for counts, CSS tokens, or UI flags",
        "patterns": [
          "^(okCount|criticalCount|warningCount|pseudoCount|failed|warnings|passed|skipped|discovered|total|pct|day|year|month|index|icon|statusColor|chunkNo|currentOffset|knownTotal|options|currentVacHtml|nextVacHtml|waButton|rowsHtml|cachedHtml|partial|safeAction|safeDateStr)\\b",
          "^(isSent|isReady|isToday|isSelected|isBlocked)\\s*\\?",
          "^!(STATE|result)",
          "^STATE\\.selectedDate",
          "^action\\s*===",
          "^sentItems\\.length",
          "^readyItems\\.length",
          "^blockedItems\\.length",
          "^STATE\\.healthCheckMode\\s*===",
          "^hasRealProblems\\s*\\?",
          "^hasProblems\\s*\\?",
          "^statusMessage$",
          "^message$",
          "^html\\s*\\+",
          "^html\\s*\\+=",
          "^rowsHtml$",
          "^cachedHtml$",
          "^partial\\s*\\?",
          "^itemStyle$",
          "^fmlStyle$",
          "^btnStyle$",
          "^item\\.role\\s*\\?",
          "^item\\.birthday\\s*\\?",
          "^item\\.link\\s*\\?",
          "^row\\.link\\s*\\?",
          "^person\\.phone\\s*\\?",
          "^person\\.link\\s*\\?",
          "^showHashButtons\\s*\\?",
          "^access\\.selfBindRequired",
          "^warnings\\.length\\s*\\?",
          "^protectedSheets\\.length\\s*\\?",
          "^sentItems\\.length\\s*>",
          "^readyItems\\.length\\s*>",
          "^data\\.mode\\s*===",
          "^details\\s*\\?",
          "^recommendation\\s*\\?",
          "^noteLabel\\b",
          "^cssClass\\b",
          "^isPseudo\\b",
          "^title\\b",
          "^emptyText\\b",
          "^status\\b",
          "^icon\\b"
        ]
      },
      {
        "id": "static-literals",
        "rationale": "Static string/number literals without dynamic user input",
        "patterns": [
          "^['\"]",
          "^\\d+(\\.\\d+)?$"
        ]
      }
    ]
  },
  "reviewedStandaloneSinks": {
    "reviewedAt": "2026-06-07",
    "changeReason": "P2 standalone HtmlService/innerHTML sinks reviewed outside the active sidebar targetFiles bundle",
    "requireCoverage": true,
    "files": [
      {
        "path": "ui-server/SidebarServer.gs",
        "rationale": "HtmlService sidebar shell only; dynamic content comes from reviewed Sidebar/JavaScript/Styles includes"
      },
      {
        "path": "reports/Summaries.gs",
        "rationale": "Modal output built from server summary renderer; no client-side user interpolation sink"
      },
      {
        "path": "personnel/PersonCards.gs",
        "rationale": "Person-card HtmlService host and PersonCalendar template loader; data is injected through template variables"
      },
      {
        "path": "ui/PersonCalendar.html",
        "rationale": "Standalone calendar grid uses numeric day/month/year values generated locally"
      },
      {
        "path": "tests/Stage7TestRunner.Ui.gs",
        "rationale": "Test-runner modal output is generated from internal test report HTML"
      },
      {
        "path": "sheets/MonthSheets.gs",
        "rationale": "Month switcher dialog uses static markup and controlled month sheet names"
      },
      {
        "path": "sendpanel/SendPanel.gs",
        "rationale": "Standalone WhatsApp sender dialog escapes row data before innerHTML insertion"
      },
      {
        "path": "ui-server/DialogTemplates.gs",
        "rationale": "Dialog template markup is static shell content"
      },
      {
        "path": "core/Code.gs",
        "rationale": "GAS include/template helpers load repository files by local filename only"
      },
      {
        "path": "reports/MonthlyReport.gs",
        "rationale": "Monthly report HTML uses local esc() for dynamic sheet/person/status values"
      },
      {
        "path": "ui/Js.State.html",
        "rationale": "Navigation history restores previously rendered sidebar HTML snapshots; dynamic rendering remains covered by reviewed render fragments"
      }
    ]
  },
  "preferredSinks": {
    "policy": "New template-literal interpolations should call a sanitizer sink directly; avoid adding new patterns to patterns[] unless migrating legacy code.",
    "requireSinkForNewPatterns": true,
    "sinkNamePattern": "^(escapeHtml|escapeHtmlMultiline|escapeAttr|escapeJsString|esc|escJs)\\b"
  },
  "sanitizerSinks": [
    "escapeHtml",
    "escapeHtmlMultiline",
    "escapeAttr",
    "escapeJsString",
    "esc"
  ],
  "targetFiles": [
    "ui/Js.Core.html",
    "ui/Js.Modals.html",
    "ui/Js.Render.Panel.html",
    "ui/Js.Render.Calendar.html",
    "ui/Js.Render.Results.html",
    "ui/Js.Vacations.html",
    "ui/Js.Diagnostics.html",
    "ui/Js.Actions.html",
    "ui/Js.Helpers.html",
    "ui/Js.Security.Boot.html",
    "ui/Js.Security.Util.html",
    "ui/Js.Security.Access.html",
    "ui/Js.Security.Debug.html",
    "ui/Js.Security.Login.html",
    "ui/Js.Security.DebugView.html",
    "ui/Js.Security.Policy.html",
    "ui/Js.Security.Guards.html",
    "ui/Js.Security.Forms.html",
    "ui/Js.Security.Exports.html"
  ],
  "patterns": [
    "^escapeHtml\\s*\\(",
    "^escapeHtmlMultiline\\s*\\(",
    "^esc\\s*\\(",
    "^escapeAttr\\s*\\(",
    "^escapeJsString\\s*\\(",
    "^Number\\s*\\(",
    "^renderMultilineUiReportText_\\s*\\(",
    "^renderHealthGroup\\s*\\(",
    "^renderHealthReport\\s*\\(",
    "^renderProjectTestReport\\s*\\(",
    "^renderHealthCheckModeSwitcher_\\s*\\(",
    "^renderPendingRepairsTable_\\s*\\(",
    "^renderVacationAlerts\\s*\\(",
    "^renderBirthdayResult\\s*\\(",
    "^renderSelectedRecipientSendButton_\\s*\\(",
    "^renderSupplementaryBlocks\\s*\\(",
    "^renderAccessDebugResult_\\s*\\(",
    "^normalizeError\\s*\\(",
    "^getHealthCheckModeLabel_\\s*\\(",
    "^translateLifecycle",
    "^formatOperationDate\\s*\\(",
    "^formatPhone\\s*\\(",
    "^formatBirthday",
    "^monthNames\\s*\\[",
    "^String\\s*\\(\\s*pct\\s*\\)",
    "^String\\s*\\(\\s*currentOffset",
    "^String\\s*\\(\\s*knownTotal",
    "^String\\s*\\(\\s*chunkNo",
    "^\\w+\\.length\\b",
    "^\\w+\\.map\\s*\\(\\s*escapeHtml\\s*\\)",
    "^protectedSheets\\.map\\s*\\(\\s*escapeHtml\\s*\\)",
    "^warnings\\.map\\s*\\(\\s*escapeHtml\\s*\\)",
    "^stats\\.",
    "^result\\?\\.",
    "^result\\.",
    "^data\\.(peopleCount|length)\\b",
    "^data\\.(commanderMessages|birthdayMessages|today|tomorrow)\\.length\\b",
    "^(okCount|criticalCount|warningCount|pseudoCount|failed|warnings|passed|skipped|discovered|total|pct|day|year|month|index|icon|statusColor|chunkNo|currentOffset|knownTotal|options|currentVacHtml|nextVacHtml|waButton|rowsHtml|cachedHtml|partial|safeAction|safeDateStr)\\b",
    "^(isSent|isReady|isToday|isSelected|isBlocked)\\s*\\?",
    "^!(STATE|result)",
    "^STATE\\.selectedDate",
    "^action\\s*===",
    "^sentItems\\.length",
    "^readyItems\\.length",
    "^blockedItems\\.length",
    "^renderCheckItemCompact\\s*\\(",
    "^items\\.map\\s*\\(\\s*renderCheckItemCompact\\s*\\)",
    "^preview\\.map\\s*\\(",
    "^groups\\.",
    "^checks\\.length",
    "^report\\.(ts|startedAt|durationMs|runId)",
    "^new Date\\s*\\(",
    "^getHealthCheckModeLabel_\\s*\\(\\)",
    "^renderHealthCheckModeSwitcher_\\s*\\(\\)",
    "^STATE\\.healthCheckMode\\s*===",
    "^hasRealProblems\\s*\\?",
    "^hasProblems\\s*\\?",
    "^statusMessage$",
    "^message$",
    "^html\\s*\\+",
    "^html\\s*\\+=",
    "^rowsHtml$",
    "^cachedHtml$",
    "^partial\\s*\\?",
    "^itemStyle$",
    "^fmlStyle$",
    "^btnStyle$",
    "^item\\.role\\s*\\?",
    "^item\\.birthday\\s*\\?",
    "^item\\.link\\s*\\?",
    "^row\\.link\\s*\\?",
    "^person\\.phone\\s*\\?",
    "^person\\.link\\s*\\?",
    "^showHashButtons\\s*\\?",
    "^access\\.selfBindRequired",
    "^warnings\\.length\\s*\\?",
    "^protectedSheets\\.length\\s*\\?",
    "^sentItems\\.length\\s*>",
    "^readyItems\\.length\\s*>",
    "^data\\.mode\\s*===",
    "^JSON\\.stringify\\s*\\(\\s*access",
    "^parts\\.join",
    "^details\\s*\\?",
    "^recommendation\\s*\\?",
    "^noteLabel\\b",
    "^cssClass\\b",
    "^isPseudo\\b",
    "^title\\b",
    "^emptyText\\b",
    "^status\\b",
    "^icon\\b",
    "^escJs\\s*\\(",
    "^['\"]",
    "^\\d+(\\.\\d+)?$"
  ]
}
